# -----------------------------------------------------------------------------
# SECRETS - NEVER COMMIT THESE!
# -----------------------------------------------------------------------------
config/secrets.yaml
keys/
secrets/
*.pem
*.key
.env
*.env
secrets.*
!config/secrets.example.yaml

